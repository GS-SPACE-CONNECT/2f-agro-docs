<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="2F-AGRO — Plataforma Agronômica com Tecnologia Espacial" id="mdl-2fagro-2026" version="5.0.0">
  <folder name="Motivation" id="fld-motivation" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Agricultor Familiar" id="sh-agricultor" documentation="Pequeno produtor rural, público-alvo principal. Usa o app para receber alertas e recomendações agronômicas."/>
    <element xsi:type="archimate:Stakeholder" name="Cooperativa / Assentamento" id="sh-cooperativa" documentation="Agrupa agricultores familiares. Usa o dashboard web para visão regional e coordenação coletiva."/>
    <element xsi:type="archimate:Stakeholder" name="EMATER / MAPA" id="sh-emater" documentation="Órgão extensionista. Recebe relatórios de risco via webhook para planejar visitas técnicas."/>
    <element xsi:type="archimate:Stakeholder" name="Banco / Pronaf" id="sh-banco" documentation="Financiador de crédito rural. Beneficia-se da redução de risco de safra."/>
    <element xsi:type="archimate:Stakeholder" name="ONG (CONTAG / MST)" id="sh-ong" documentation="Parceiro de inclusão tecnológica. Recebe relatórios de impacto social mensais."/>
    <element xsi:type="archimate:Driver" name="Deserto tecnológico na agricultura familiar" id="dr-deserto" documentation="77% dos estabelecimentos rurais BR são pequenos, mas toda tecnologia agrícola foca o grande agro."/>
    <element xsi:type="archimate:Driver" name="Mudanças climáticas e risco crescente de safra" id="dr-clima" documentation="Eventos extremos (geada, seca, excesso chuva) sem aviso prévio causam prejuízo de R$10-50k por família."/>
    <element xsi:type="archimate:Driver" name="Acesso limitado a crédito rural (Pronaf)" id="dr-credito" documentation="Bancos restringem Pronaf por risco não mensurado. Dados de risco reduzem inadimplência."/>
    <element xsi:type="archimate:Goal" name="Reduzir perda de safra em 30%" id="goal-safra"/>
    <element xsi:type="archimate:Goal" name="Democratizar tecnologia espacial para pequenos produtores" id="goal-democratizar"/>
    <element xsi:type="archimate:Goal" name="Aumentar resiliência climática regional" id="goal-resiliencia"/>
    <element xsi:type="archimate:Goal" name="Escalar apoio extensionista da EMATER" id="goal-emater"/>
    <element xsi:type="archimate:Requirement" name="Funcionar offline (menos de 5MB por mês)" id="req-offline"/>
    <element xsi:type="archimate:Requirement" name="Interface acessível: áudio TTS, ícones grandes, fonte 18sp" id="req-acessivel"/>
    <element xsi:type="archimate:Requirement" name="Compatível com Android 7 e celular básico" id="req-android"/>
    <element xsi:type="archimate:Requirement" name="Conformidade LGPD: consentimento, auditoria, direito ao esquecimento" id="req-lgpd"/>
    <element xsi:type="archimate:Requirement" name="Latência de inferência ML menor que 500ms" id="req-latencia"/>
    <element xsi:type="archimate:Constraint" name="Dataset simulado FIAP (CSV)" id="con-dataset"/>
    <element xsi:type="archimate:Constraint" name="Prazo de entrega: 09/06/2026" id="con-prazo"/>
    <element xsi:type="archimate:Constraint" name="Equipe de 5 pessoas" id="con-equipe"/>
    <element xsi:type="archimate:Principle" name="Acessibilidade radical: o agricultor não precisa entender tecnologia" id="pr-acessibilidade"/>
    <element xsi:type="archimate:Principle" name="IA invisível: mostra resultado, não fórmula" id="pr-ia"/>
    <element xsi:type="archimate:Principle" name="Dados coletivos só com consentimento explícito (LGPD)" id="pr-lgpd"/>
  </folder>
  <folder name="Business" id="fld-business" type="business">
    <element xsi:type="archimate:BusinessActor" name="Agricultor Familiar" id="ba-agricultor"/>
    <element xsi:type="archimate:BusinessActor" name="Gestor de Cooperativa" id="ba-gestor"/>
    <element xsi:type="archimate:BusinessActor" name="Extensionista EMATER" id="ba-extensionista"/>
    <element xsi:type="archimate:BusinessActor" name="Administrador 2F-AGRO" id="ba-admin"/>
    <element xsi:type="archimate:BusinessRole" name="Produtor Rural" id="br-produtor"/>
    <element xsi:type="archimate:BusinessRole" name="Gestor Regional" id="br-gestor"/>
    <element xsi:type="archimate:BusinessRole" name="Agrônomo" id="br-agronomo"/>
    <element xsi:type="archimate:BusinessRole" name="Administrador de Sistema" id="br-admin"/>
    <element xsi:type="archimate:BusinessProcess" name="Monitorar Propriedade Rural" id="bp-monitorar" documentation="Agricultor abre o app e visualiza o status atual da lavoura com cor semafórica."/>
    <element xsi:type="archimate:BusinessProcess" name="Detectar Risco Agronômico" id="bp-detectar" documentation="Sistema processa dados de satélite + sensores e executa modelo ML para gerar índice de risco."/>
    <element xsi:type="archimate:BusinessProcess" name="Identificar Praga por Fotografia" id="bp-praga" documentation="Agricultor fotografa folha suspeita; sistema identifica praga/doença via visão computacional."/>
    <element xsi:type="archimate:BusinessProcess" name="Recomendar Ação Agronômica" id="bp-recomendar" documentation="Sistema gera recomendação direta baseada no risco detectado e na cultura plantada."/>
    <element xsi:type="archimate:BusinessProcess" name="Coordenar Ação Coletiva da Cooperativa" id="bp-coordenar" documentation="Gestor usa dashboard para disparar alertas para toda a cooperativa quando risco regional é alto."/>
    <element xsi:type="archimate:BusinessProcess" name="Acompanhar Resultado da Safra" id="bp-acompanhar" documentation="Agricultor registra ações tomadas e acompanha histórico de risco nos últimos 30 dias."/>
    <element xsi:type="archimate:BusinessProcess" name="Reportar a EMATER" id="bp-reportar" documentation="Sistema envia automaticamente relatório de risco regional para extensionistas via webhook."/>
    <element xsi:type="archimate:BusinessService" name="Diagnóstico Agronômico" id="bs-diagnostico"/>
    <element xsi:type="archimate:BusinessService" name="Alerta Preventivo de Risco" id="bs-alerta"/>
    <element xsi:type="archimate:BusinessService" name="Recomendação Inteligente de Ação" id="bs-recomendacao"/>
    <element xsi:type="archimate:BusinessService" name="Identificação de Pragas e Doenças" id="bs-praga"/>
    <element xsi:type="archimate:BusinessService" name="Visão Coletiva Regional" id="bs-visao"/>
    <element xsi:type="archimate:BusinessObject" name="Propriedade Rural" id="bo-propriedade"/>
    <element xsi:type="archimate:BusinessObject" name="Alerta de Risco de Safra" id="bo-alerta"/>
    <element xsi:type="archimate:BusinessObject" name="Recomendação Agronômica" id="bo-recomendacao"/>
    <element xsi:type="archimate:BusinessObject" name="Diagnóstico de Praga" id="bo-diagnostico"/>
    <element xsi:type="archimate:BusinessObject" name="Relatório de Safra Regional" id="bo-relatorio"/>
  </folder>
  <folder name="Application" id="fld-application" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="App Mobile 2F-AGRO" id="ac-mobile" documentation="React Native + Expo. Offline-first, Android 7+. Interface acessível com áudio TTS, ícones grandes."/>
    <element xsi:type="archimate:ApplicationComponent" name="Web Dashboard (Cooperativa)" id="ac-dashboard" documentation="React + Leaflet. Mapa interativo de risco regional, exportação CSV/PDF, webhooks EMATER."/>
    <element xsi:type="archimate:ApplicationComponent" name="API Gateway" id="ac-gateway" documentation="C# .NET 8 Web API. Roteamento, rate limiting, autenticação OAuth2/JWT para todos os microsserviços."/>
    <element xsi:type="archimate:ApplicationComponent" name="Serviço ML Agro" id="ac-ml" documentation="Python FastAPI + scikit-learn. Regressão Logística + Árvore de Decisão + K-Means para perfil agronômico."/>
    <element xsi:type="archimate:ApplicationComponent" name="Serviço Visão de Pragas" id="ac-visao" documentation="Python + YOLOv8 + OpenCV. Detecta pragas e doenças em folhas via câmera do celular em menos de 3s."/>
    <element xsi:type="archimate:ApplicationComponent" name="Serviço de Alertas Agro" id="ac-alertas" documentation="C# .NET 8 + EF Core. Regras agronômicas, persistência de alertas e recomendações por cultura."/>
    <element xsi:type="archimate:ApplicationComponent" name="Serviço de Notificação" id="ac-notif" documentation="C# .NET + RabbitMQ. Envia push via Expo/FCM em até 5 min após detecção de risco ALTO."/>
    <element xsi:type="archimate:ApplicationComponent" name="Serviço Auth e Auditoria LGPD" id="ac-auth" documentation="C# Identity + JWT. OAuth2, hash bcrypt, blacklist de tokens, log imutável de acesso para LGPD."/>
    <element xsi:type="archimate:ApplicationComponent" name="Serviço de Ingestão" id="ac-ingestao" documentation="Python + pandas. Processa CSV de satélite (6h) e recebe dados MQTT da estação edge (15 min)."/>
    <element xsi:type="archimate:ApplicationService" name="REST API Propriedades" id="as-rest" documentation="GET/POST /api/propriedades — CRUD de propriedades rurais com geolocalização."/>
    <element xsi:type="archimate:ApplicationService" name="Inferência de Risco ML" id="as-ml" documentation="POST /api/ml/inferir — Retorna {risco, probabilidade, motivo} em menos de 500ms."/>
    <element xsi:type="archimate:ApplicationService" name="Detecção de Pragas por CV" id="as-cv" documentation="POST /api/visao/praga — Classifica praga em imagem de folha com YOLOv8."/>
    <element xsi:type="archimate:ApplicationService" name="Push Notifications" id="as-push" documentation="Expo Push API — Alerta no celular do agricultor sobre risco ALTO."/>
    <element xsi:type="archimate:ApplicationService" name="Autenticação OAuth2 e JWT" id="as-auth" documentation="POST /api/auth/token — Login com CPF+senha, JWT 8h, refresh 30 dias."/>
    <element xsi:type="archimate:ApplicationService" name="Webhook EMATER" id="as-webhook" documentation="POST {url_emater} — Relatório diário às 7h com dados de risco regional anonimizados."/>
    <element xsi:type="archimate:DataObject" name="Dados NDVI de Satélite" id="do-ndvi" documentation="NDVI, umidade solo, cobertura nuvens, chuva prevista, temperatura — CSV simulado FIAP."/>
    <element xsi:type="archimate:DataObject" name="Dados de Sensores Edge" id="do-sensor" documentation="Temperatura, umidade relativa, pluviometria, velocidade do vento — Raspberry Pi na fazenda."/>
    <element xsi:type="archimate:DataObject" name="Imagem de Folha" id="do-imagem" documentation="Foto tirada pelo agricultor via câmera do celular para diagnóstico de praga."/>
    <element xsi:type="archimate:DataObject" name="Perfil Agronômico (Cluster)" id="do-perfil" documentation="Segmentação K-Means (k=4): Zona Seca, Área Chuvosa, Encosta Vulnerável, Propriedade Estável."/>
    <element xsi:type="archimate:DataObject" name="Histórico de Alertas" id="do-historico" documentation="Série temporal de alertas, probabilidades e ações tomadas — últimos 30 dias por propriedade."/>
    <element xsi:type="archimate:DataObject" name="Log de Auditoria LGPD" id="do-auditoria" documentation="Registro imutável append-only: user_id, propriedade_id, timestamp, IP — retenção 5 anos."/>
  </folder>
  <folder name="Technology &amp; Physical" id="fld-technology" type="technology">
    <element xsi:type="archimate:Node" name="Cloud Azure ou AWS" id="tn-cloud" documentation="Hospeda todos os microsserviços containerizados e o banco de dados PostgreSQL."/>
    <element xsi:type="archimate:Node" name="Estação Edge na Fazenda (Raspberry Pi)" id="tn-edge" documentation="Raspberry Pi Zero 2W com painel solar 5W. Instalada na propriedade rural sem energia elétrica."/>
    <element xsi:type="archimate:Node" name="Celular do Agricultor (Android 7+)" id="tn-mobile" documentation="Celular Android básico. Roda o app React Native com modelo YOLO lite para diagnóstico offline."/>
    <element xsi:type="archimate:Node" name="Satélite Simulado (CSV FIAP)" id="tn-satelite" documentation="Fonte de dados orbitais simulada pelo dataset oficial da FIAP. 320 registros de propriedades rurais."/>
    <element xsi:type="archimate:Device" name="Raspberry Pi Zero 2W" id="dev-raspi" documentation="Hardware da estação edge. Consome menos de 2W. Alimentado por painel solar de 5W."/>
    <element xsi:type="archimate:Device" name="Sensores DHT22 e Pluviômetro" id="dev-sensores" documentation="DHT22: temperatura + umidade. Pluviômetro: precipitação. Anemômetro: velocidade do vento."/>
    <element xsi:type="archimate:SystemSoftware" name="Raspbian Custom OS" id="ss-raspbian" documentation="Sistema operacional customizado para a estação edge. Baseado em Debian 12, otimizado para baixo consumo."/>
    <element xsi:type="archimate:SystemSoftware" name="Docker e Kubernetes" id="ss-docker" documentation="Orquestração de containers na nuvem. Deploy de todos os microsserviços 2F-AGRO."/>
    <element xsi:type="archimate:SystemSoftware" name="Android 7 (Nougat) ou superior" id="ss-android" documentation="Sistema operacional do celular do agricultor. Requerimento mínimo do app React Native."/>
    <element xsi:type="archimate:TechnologyService" name="PostgreSQL 15 com PostGIS" id="ts-postgres" documentation="Banco relacional com extensão geoespacial. Armazena propriedades, alertas, séries temporais e audit log."/>
    <element xsi:type="archimate:TechnologyService" name="RabbitMQ 3.12" id="ts-rabbitmq" documentation="Fila de mensagens para desacoplar detecção de risco do envio de notificações push."/>
    <element xsi:type="archimate:TechnologyService" name="S3 ou Azure Blob Storage" id="ts-s3" documentation="Armazena imagens de folhas, modelos ML (.pkl) e pesos YOLO (.pt)."/>
    <element xsi:type="archimate:TechnologyService" name="HTTPS com TLS 1.3" id="ts-tls" documentation="Toda comunicação entre app, dashboard e API Gateway é criptografada."/>
    <element xsi:type="archimate:TechnologyService" name="MQTT Broker" id="ts-mqtt" documentation="Protocolo IoT leve para comunicação entre estação edge e serviço de ingestão na nuvem."/>
    <element xsi:type="archimate:TechnologyService" name="SQLite Local" id="ts-sqlite" documentation="Banco local no celular do agricultor para modo offline. Sincroniza com PostgreSQL quando online."/>
    <element xsi:type="archimate:CommunicationNetwork" name="Internet 4G ou 5G ou WiFi" id="cn-internet" documentation="Conexão entre celular do agricultor e API Gateway na nuvem."/>
    <element xsi:type="archimate:CommunicationNetwork" name="LoRa ou WiFi Local (Edge)" id="cn-lora" documentation="Comunicação entre estação edge na fazenda e roteador ou gateway de internet."/>
    <element xsi:type="archimate:Artifact" name="Modelo ML scikit-learn (.pkl)" id="ar-modelo" documentation="Modelos treinados: Regressão Logística + Árvore de Decisão + K-Means. Armazenados em S3."/>
    <element xsi:type="archimate:Artifact" name="Dataset CSV FIAP" id="ar-dataset" documentation="dataset_space_risk_global_solution.csv — 320 propriedades, 14 colunas, dados simulados."/>
    <element xsi:type="archimate:Artifact" name="Pesos YOLO v8 (.pt)" id="ar-yolo" documentation="Pesos do modelo fine-tuned em PlantVillage para detecção de 5 pragas/doenças em folhas."/>
  </folder>
